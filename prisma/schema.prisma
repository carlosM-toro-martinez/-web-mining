generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////
// SISTEMA
////////////////////////////////

model Configuracion {
  id           Int          @id @default(autoincrement())
  metodoCosteo MetodoCosteo @default(ULTIMO_PRECIO)
  createdAt    DateTime     @default(now())
}

model User {
  id                    Int             @id @default(autoincrement())
  nombre                String
  email                 String          @unique
  password              String
  role                  Role
  createdAt             DateTime        @default(now())
  resetToken            String?
  resetTokenExpiry      DateTime?
  refreshToken          String?
  refreshTokenExpiry    DateTime?
  activo                Boolean         @default(true)
  comprasRecibidas      Compra[]        @relation("UsuarioRecibe")
  comprasRegistradas    Compra[]        @relation("UsuarioRegistro")
  anulacionesCompra     AnulacionCompra[]
  eppAsignaciones       EppAsignacion[]
  logs                  Log[]
  movimientosEntregados Movimiento[]    @relation("UsuarioEntrega")
  movimientos           Movimiento[]    @relation("UsuarioRegistro")
  movimientosRecibidos  Movimiento[]    @relation("UsuarioRecibido")
  valesEntregadosPor    Vale[]          @relation("Almacenero")
  valesSolicitados      Vale[]          @relation("Solicitante")
  valesAprobados        Vale[]          @relation("Supervisor")
  anulaciones           AnulacionVale[]
  registrosHidricos    RegistroHidrico[]
  registrosResiduo     RegistroResiduo[]
  registrosRuido       RegistroRuido[]
  registrosSuelo       RegistroSuelo[]
  manifiestos          ManifiestoAmbiental[]
}

model Log {
  id        String   @id @default(uuid())
  usuarioId Int?
  accion    String
  data      Json
  createdAt DateTime @default(now())
  usuario   User?    @relation(fields: [usuarioId], references: [id])
}

////////////////////////////////
// INVENTARIO
////////////////////////////////

////////////////////////////////
// CONTABILIDAD
////////////////////////////////

model CentroCosto {
  id      Int              @id @default(autoincrement())
  codigo  String           @unique
  nombre  String
  cuentas CuentaContable[]
}

model FuncionGasto {
  id      Int              @id @default(autoincrement())
  codigo  String           @unique
  nombre  String
  cuentas CuentaContable[]
}

model Sector {
  id      Int              @id @default(autoincrement())
  codigo  String           @unique
  nombre  String
  cuentas CuentaContable[]
}

model CuentaContable {
  id             Int          @id @default(autoincrement())
  codigoCompleto String       @unique
  centroCostoId  Int
  funcionGastoId Int
  sectorId       Int?
  centroCosto    CentroCosto  @relation(fields: [centroCostoId], references: [id])
  funcionGasto   FuncionGasto @relation(fields: [funcionGastoId], references: [id])
  sector         Sector?      @relation(fields: [sectorId], references: [id])
  movimientos    Movimiento[]
  productos      Producto[]
}

model CategoriaInventario {
  id        Int                   @id @default(autoincrement())
  codigo    String
  nombre    String
  parentId  Int?
  parent    CategoriaInventario?  @relation("Tree", fields: [parentId], references: [id])
  children  CategoriaInventario[] @relation("Tree")
  productos Producto[]
}

model Producto {
  id               Int                 @id @default(autoincrement())
  codigo           String              @unique
  nombre           String
  unidad           String
  categoriaId      Int
  esEpp            Boolean             @default(false)
  cuentaId         Int?
  compraItems      CompraItem[]
  eppAsignaciones  EppAsignacion[]
  movimientos      Movimiento[]
  pedidoItems      PedidoItem[]
  saldosMensuales  SaldoMensual[]
  categoria        CategoriaInventario @relation(fields: [categoriaId], references: [id])
  cuenta           CuentaContable?     @relation(fields: [cuentaId], references: [id])
  stock            Stock?
  valeItems        ValeItem[]
}

model SaldoMensual {
  id             String   @id @default(uuid())
  productoId     Int
  anio           Int
  mes            Int
  saldoInicial   Decimal  @default(0) @db.Decimal(14, 4)
  ingresoQty     Decimal  @default(0) @db.Decimal(14, 4)
  salidaQty      Decimal  @default(0) @db.Decimal(14, 4)
  saldoFinal     Decimal  @default(0) @db.Decimal(14, 4)
  precioUnit     Decimal  @default(0) @db.Decimal(14, 4)  // último precio de compra del período
  totalBs        Decimal  @default(0) @db.Decimal(14, 4)  // saldoFinal × precioUnit
  totalBsInicial Decimal? @db.Decimal(14, 2)             // override manual del monto inicial en Bs
  ingresosBs     Decimal  @default(0) @db.Decimal(14, 4)  // suma(cantidad × precioUnit) de todas las entradas → para calcular promedio
  precioUnitProm Decimal  @default(0) @db.Decimal(14, 6)  // promedio ponderado = ingresosBs / ingresoQty
  totalBsProm    Decimal  @default(0) @db.Decimal(14, 6)  // saldoFinal × precioUnitProm
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  producto       Producto @relation(fields: [productoId], references: [id])

  @@unique([productoId, anio, mes])
  @@index([anio, mes])
}

model Stock {
  id                Int      @id @default(autoincrement())
  productoId        Int      @unique
  cantidad          Decimal  @db.Decimal(12, 2)
  cantidadReservada Decimal  @default(0) @db.Decimal(12, 2)
  precioUnit        Decimal  @db.Decimal(14, 6)
  precioProm        Decimal  @db.Decimal(14, 6)
  updatedAt         DateTime @updatedAt
  producto          Producto @relation(fields: [productoId], references: [id])
}

model Movimiento {
  id                String          @id @default(uuid())
  operationId       String          @unique
  productoId        Int
  tipo              TipoMovimiento
  cantidad          Decimal         @db.Decimal(12, 2)
  precioUnit        Decimal         @db.Decimal(14, 6)
  entradaBs         Decimal         @default(0) @db.Decimal(12, 2)
  salidaBs          Decimal         @default(0) @db.Decimal(12, 2)
  saldoBs           Decimal         @db.Decimal(12, 2)
  stockAntes        Decimal         @db.Decimal(12, 2)
  stockDespues      Decimal         @db.Decimal(12, 2)
  usuarioId         Int
  cuentaId          Int?
  referencia        String?
  referenciaId      String?
  esRetroactivo     Boolean         @default(false)
  periodoAnio       Int?
  periodoMes        Int?
  createdAt         DateTime        @default(now())
  usuarioEntregaId  Int?
  usuarioRecibidoId Int?
  cuenta            CuentaContable? @relation(fields: [cuentaId], references: [id])
  producto          Producto        @relation(fields: [productoId], references: [id])
  usuarioEntrega    User?           @relation("UsuarioEntrega", fields: [usuarioEntregaId], references: [id])
  usuario           User            @relation("UsuarioRegistro", fields: [usuarioId], references: [id])
  usuarioRecibido   User?           @relation("UsuarioRecibido", fields: [usuarioRecibidoId], references: [id])
}

////////////////////////////////
// COMPRAS
////////////////////////////////

model Proveedor {
  id          Int      @id @default(autoincrement())
  nombre      String
  contacto    String?
  lugar       String?
  nit         String?
  razonSocial String?
  compras     Compra[]
  pedidos     Pedido[]
}

model Pedido {
  id          String       @id @default(uuid())
  proveedorId Int
  estado      EstadoPedido
  createdAt   DateTime     @default(now())
  observacion String?
  proveedor   Proveedor    @relation(fields: [proveedorId], references: [id])
  items       PedidoItem[]
}

model PedidoItem {
  id               String   @id @default(uuid())
  pedidoId         String
  productoId       Int
  cantidadPedida   Decimal  @db.Decimal(12, 2)
  cantidadRecibida Decimal  @default(0) @db.Decimal(12, 2)
  pedido           Pedido   @relation(fields: [pedidoId], references: [id])
  producto         Producto @relation(fields: [productoId], references: [id])
}

model Compra {
  id                String       @id @default(uuid())
  proveedorId       Int
  estado            EstadoCompra
  createdAt         DateTime     @default(now())
  observacion       String?
  numeroFactura     String?
  descuento         Decimal      @default(0) @db.Decimal(5, 2)
  recibidoAt        DateTime?
  fechaOperacion    DateTime?
  usuarioRecibidoId Int?
  usuarioRegistroId Int
  tieneIva          Boolean          @default(true)
  proveedor         Proveedor        @relation(fields: [proveedorId], references: [id])
  usuarioRecibe     User?            @relation("UsuarioRecibe", fields: [usuarioRecibidoId], references: [id])
  usuarioRegistro   User             @relation("UsuarioRegistro", fields: [usuarioRegistroId], references: [id])
  items             CompraItem[]
  anulacion         AnulacionCompra?
}

model CompraItem {
  id               String   @id @default(uuid())
  compraId         String
  productoId       Int
  cantidadPedida   Decimal  @db.Decimal(12, 2)
  cantidadRecibida Decimal  @default(0) @db.Decimal(12, 2)
  precioUnit       Decimal  @db.Decimal(14, 6)
  compra           Compra   @relation(fields: [compraId], references: [id])
  producto         Producto @relation(fields: [productoId], references: [id])
}

////////////////////////////////
// VALES / EPP
////////////////////////////////

model Vale {
  id                String          @id @default(uuid())
  solicitanteId     Int
  superintendenteId Int?
  estado            EstadoVale
  aprobadoAt        DateTime?
  entregadoAt       DateTime?
  fechaOperacion    DateTime?
  createdAt         DateTime        @default(now())
  almaceneroId      Int?
  almacenero        User?           @relation("Almacenero", fields: [almaceneroId], references: [id])
  solicitante       User            @relation("Solicitante", fields: [solicitanteId], references: [id])
  superintendente   User?           @relation("Supervisor", fields: [superintendenteId], references: [id])
  items             ValeItem[]
  anulacion         AnulacionVale?
}

model AnulacionVale {
  id         String   @id @default(uuid())
  valeId     String   @unique
  usuarioId  Int
  motivo     String
  createdAt  DateTime @default(now())
  vale       Vale     @relation(fields: [valeId], references: [id])
  usuario    User     @relation(fields: [usuarioId], references: [id])
}

model AnulacionCompra {
  id        String   @id @default(uuid())
  compraId  String   @unique
  usuarioId Int
  motivo    String
  createdAt DateTime @default(now())
  compra    Compra   @relation(fields: [compraId], references: [id])
  usuario   User     @relation(fields: [usuarioId], references: [id])
}

model ValeItem {
  id                 String   @id @default(uuid())
  valeId             String
  productoId         Int
  cantidadSolicitada Decimal  @db.Decimal(12, 2)
  cantidadEntregada  Decimal  @default(0) @db.Decimal(12, 2)
  producto           Producto @relation(fields: [productoId], references: [id])
  vale               Vale     @relation(fields: [valeId], references: [id])
}

model EppAsignacion {
  id              String       @id @default(uuid())
  productoId      Int
  usuarioId       Int
  fechaEntrega    DateTime     @default(now())
  fechaDevolucion DateTime?
  condicion       CondicionEpp @default(EN_USO)
  observacion     String?
  producto        Producto     @relation(fields: [productoId], references: [id])
  usuario         User         @relation(fields: [usuarioId], references: [id])

  @@index([productoId])
  @@index([usuarioId])
}

////////////////////////////////
// AMBIENTAL
////////////////////////////////

model PuntoMonitoreo {
  id          Int       @id @default(autoincrement())
  nombre      String
  descripcion String?
  latitud     Float
  longitud    Float
  tipo        TipoPunto @default(GENERAL)
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  registrosHidricos RegistroHidrico[]
  registrosResiduo  RegistroResiduo[]
  registrosRuido    RegistroRuido[]
  registrosSuelo    RegistroSuelo[]

  @@index([tipo])
}

model RegistroHidrico {
  id                Int            @id @default(autoincrement())
  puntoId           Int
  fecha             DateTime
  ph                Float?
  turbidez          Float?
  conductividad     Float?
  oxigenoDisuelto   Float?
  temperatura       Float?
  coliformesFecales Float?
  calidadAgua       CalidadAgua    @default(BUENA)
  observaciones     String?
  usuarioId         Int
  createdAt         DateTime       @default(now())

  punto   PuntoMonitoreo @relation(fields: [puntoId], references: [id])
  usuario User           @relation(fields: [usuarioId], references: [id])

  @@index([puntoId])
  @@index([fecha])
}

model RegistroResiduo {
  id            Int         @id @default(autoincrement())
  puntoId       Int?
  fecha         DateTime
  tipoResiduo   TipoResiduo
  cantidad      Float
  unidad        String
  disposicion   String
  empresa       String?
  manifiestoNum String?
  observaciones String?
  usuarioId     Int
  createdAt     DateTime    @default(now())

  punto   PuntoMonitoreo? @relation(fields: [puntoId], references: [id])
  usuario User            @relation(fields: [usuarioId], references: [id])

  @@index([puntoId])
  @@index([fecha])
}

model RegistroRuido {
  id               Int            @id @default(autoincrement())
  puntoId          Int
  fecha            DateTime
  nivelRuido       Float
  limitePermitido  Float?
  particulasPm10   Float?
  particulasPm25   Float?
  observaciones    String?
  usuarioId        Int
  createdAt        DateTime       @default(now())

  punto   PuntoMonitoreo @relation(fields: [puntoId], references: [id])
  usuario User           @relation(fields: [usuarioId], references: [id])

  @@index([puntoId])
  @@index([fecha])
}

model RegistroSuelo {
  id                  Int            @id @default(autoincrement())
  puntoId             Int
  fecha               DateTime
  ph                  Float?
  conductividad       Float?
  materiaOrganica     Float?
  especiesRegistradas String?
  observaciones       String?
  usuarioId           Int
  createdAt           DateTime       @default(now())

  punto   PuntoMonitoreo @relation(fields: [puntoId], references: [id])
  usuario User           @relation(fields: [usuarioId], references: [id])

  @@index([puntoId])
  @@index([fecha])
}

model PozoSeptico {
  id              Int                   @id @default(autoincrement())
  nombre          String
  descripcion     String?
  latitud         Float
  longitud        Float
  capacidadM3     Float?
  estado          EstadoInfraestructura @default(BUENO)
  ultimaLimpieza  DateTime?
  proximaLimpieza DateTime?
  observaciones   String?
  activo          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model ManifiestoAmbiental {
  id          Int       @id @default(autoincrement())
  anio        Int
  titulo      String
  descripcion String?
  objetivos   String?
  compromisos String?
  responsable String?
  aprobadoAt  DateTime?
  usuarioId   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  usuario User @relation(fields: [usuarioId], references: [id])

  @@index([anio])
}

////////////////////////////////
// BIOMÉTRICO / ASISTENCIA
////////////////////////////////

model Employee {
  id             Int               @id @default(autoincrement())
  nombre         String
  documento      String?           @unique
  cargo          String?
  tipoPersonal   TipoPersonal      @default(OBRERO)
  deviceUserId   String            @unique
  activo         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  syncStatus     SyncStatus        @default(PENDING)
  logs           AsistenciaLog[]
  horarios       EmpleadoHorario[]
  ausencias      AusenciaEmpleado[]
}

model Horario {
  id          Int               @id @default(autoincrement())
  nombre      String
  descripcion String?
  horaEntrada String            // "HH:MM" hora local Bolivia
  horaSalida  String            // "HH:MM" hora local Bolivia
  tolerancia  Int               @default(15) // minutos de tolerancia para tardanza
  lunes       Boolean           @default(true)
  martes      Boolean           @default(true)
  miercoles   Boolean           @default(true)
  jueves      Boolean           @default(true)
  viernes     Boolean           @default(true)
  sabado      Boolean           @default(false)
  domingo     Boolean           @default(false)
  activo      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  asignaciones EmpleadoHorario[]
}

model EmpleadoHorario {
  id         Int       @id @default(autoincrement())
  employeeId Int
  horarioId  Int
  desde      DateTime  // fecha desde la que aplica este horario
  hasta      DateTime? // null = vigente actualmente
  createdAt  DateTime  @default(now())

  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  horario    Horario   @relation(fields: [horarioId], references: [id])

  @@index([employeeId])
  @@index([horarioId])
}

model AusenciaEmpleado {
  id         Int          @id @default(autoincrement())
  employeeId Int
  tipo       AusenciaTipo
  desde      DateTime     // inicio del período (fecha, hora ignorada)
  hasta      DateTime     // fin del período inclusivo (fecha, hora ignorada)
  motivo     String?
  aprobado   Boolean      @default(false)
  creadoPor  String?      // nombre o ID del que aprueba
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([desde, hasta])
}

model SyncQueue {
  id        Int        @id @default(autoincrement())
  action    SyncAction
  payload   Json
  status    SyncStatus @default(PENDING)
  deviceIp  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model DeviceState {
  sn        String   @id
  lastSeen  DateTime
  updatedAt DateTime @updatedAt
}

model CierreMes {
  id        Int      @id @default(autoincrement())
  anio      Int
  mes       Int
  usuarioId Int
  creadoAt  DateTime @default(now())

  @@unique([anio, mes])
}

model AsistenciaLog {
  id           Int       @id @default(autoincrement())
  employeeId   Int?
  deviceUserId String
  fecha        DateTime
  tipo         String
  employee     Employee? @relation(fields: [employeeId], references: [id])

  @@unique([deviceUserId, fecha])
  @@index([fecha])
  @@index([employeeId])
}

////////////////////////////////
// ENUMS
////////////////////////////////

enum MetodoCosteo {
  ULTIMO_PRECIO
  PROMEDIO_PONDERADO
}

enum Role {
  ADMIN
  ALMACENERO
  SUPERINTENDENTE
  TRABAJADOR
  VISITANTE
  GEOLOGOADMIN
  GEOLOGO
  ADMINISTRADOR
  MEDIOAMBIENTE
  SEGURIDAD
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
}

enum EstadoPedido {
  PENDIENTE
  PARCIAL
  COMPLETADO
}

enum EstadoCompra {
  PENDIENTE
  PARCIAL
  COMPLETADO
  ANULADA
}

enum EstadoVale {
  PENDIENTE
  APROBADO
  PARCIAL
  COMPLETADO
  RECHAZADO
  ANULADO
}

enum SyncStatus {
  PENDING
  SYNCED
  ERROR
}

enum TipoPersonal {
  OBRERO
  TECNICO_EMPLEADO
}

enum SyncAction {
  CREATE
  UPDATE
  DELETE
}

enum AusenciaTipo {
  VACACION
  DESCANSO
  PERMISO
  ENFERMEDAD
  FERIADO
  ABANDONO
  OTRO
}

enum CondicionEpp {
  NUEVO
  EN_USO
  DEVUELTO_BUENO
  DEVUELTO_USADO
  BAJA
}

enum TipoPunto {
  HIDRICO
  SUELO
  RUIDO
  RESIDUOS
  POZO_SEPTICO
  GENERAL
}

enum CalidadAgua {
  EXCELENTE
  BUENA
  REGULAR
  MALA
  CRITICA
}

enum TipoResiduo {
  SOLIDO_PELIGROSO
  SOLIDO_NO_PELIGROSO
  LIQUIDO_PELIGROSO
  LIQUIDO_NO_PELIGROSO
}

enum EstadoInfraestructura {
  BUENO
  REGULAR
  MALO
  CRITICO
}

