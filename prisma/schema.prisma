// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// generator client {
//   provider = "prisma-client"
//   output   = "../src/generated/prisma"
// }

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////
// CONFIGURACIÓN GLOBAL //
//////////////////////////

model Configuracion {
  id           Int          @id @default(autoincrement())
  metodoCosteo MetodoCosteo @default(ULTIMO_PRECIO)
  createdAt    DateTime     @default(now())
}

enum MetodoCosteo {
  ULTIMO_PRECIO
  PROMEDIO_PONDERADO
}

//////////////////////////
// USUARIOS             //
//////////////////////////

model User {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  activo    Boolean  @default(true)

  resetToken       String?
  resetTokenExpiry DateTime?

  refreshToken     String?
  refreshTokenExpiry DateTime?

  movimientos Movimiento[] @relation("UsuarioRegistro")
  movimientosEntregados Movimiento[] @relation("UsuarioEntrega")
  movimientosRecibidos Movimiento[] @relation("UsuarioRecibido")
  logs        Log[]
  eppAsignaciones EppAsignacion[]

  valesSolicitados Vale[] @relation("Solicitante")
  valesAprobados   Vale[] @relation("Supervisor")
  valesEntregadosPor Vale[] @relation("Almacenero")

  comprasRegistradas Compra[] @relation("UsuarioRegistro")
  comprasRecibidas Compra[] @relation("UsuarioRecibe")

  muestras Muestra[]
}

enum Role {
  ADMIN
  ALMACENERO
  SUPERINTENDENTE
  TRABAJADOR
}

//////////////////////////
// CATEGORÍA INVENTARIO //
//////////////////////////

model CategoriaInventario {
  id       Int    @id @default(autoincrement())
  codigo   String
  nombre   String

  parentId Int?
  parent   CategoriaInventario? @relation("Tree", fields: [parentId], references: [id])
  children CategoriaInventario[] @relation("Tree")

  productos Producto[]
}

//////////////////////////
// CONTABILIDAD         //
//////////////////////////

model CentroCosto {
  id      Int    @id @default(autoincrement())
  codigo  String @unique
  nombre  String

  cuentas CuentaContable[]
}

model FuncionGasto {
  id      Int    @id @default(autoincrement())
  codigo  String @unique
  nombre  String

  cuentas CuentaContable[]
}

model Sector {
  id     Int    @id @default(autoincrement())
  codigo String @unique
  nombre String

  cuentas CuentaContable[]
}

model CuentaContable {
  id             Int @id @default(autoincrement())
  codigoCompleto String @unique

  centroCostoId  Int
  funcionGastoId Int
  sectorId       Int? 

  centroCosto  CentroCosto  @relation(fields: [centroCostoId], references: [id])
  funcionGasto FuncionGasto @relation(fields: [funcionGastoId], references: [id])
  sector       Sector? @relation(fields: [sectorId], references: [id])
  
  movimientos Movimiento[]
  productos   Producto[]
}

//////////////////////////
// PRODUCTOS            //
//////////////////////////

model Producto {
  id          Int    @id @default(autoincrement())
  codigo      String @unique
  nombre      String
  unidad      String

  categoriaId Int
  categoria   CategoriaInventario @relation(fields: [categoriaId], references: [id])

  cuentaId    Int?
  cuenta      CuentaContable? @relation(fields: [cuentaId], references: [id])

  esEpp       Boolean @default(false)

  stock       Stock?
  movimientos Movimiento[]
  compraItems CompraItem[]
  valeItems   ValeItem[]
  eppAsignaciones EppAsignacion[]
  pedidoItems PedidoItem[]
}

//////////////////////////
// STOCK                //
//////////////////////////

model Stock {
  id         Int @id @default(autoincrement())
  productoId Int @unique

  cantidad   Decimal @db.Decimal(12,2)
  precioUnit Decimal @db.Decimal(12,2)   // último precio
  precioProm Decimal @db.Decimal(12,2)   // promedio ponderado

  updatedAt  DateTime @updatedAt

  producto   Producto @relation(fields: [productoId], references: [id])
}

//////////////////////////
// MOVIMIENTOS (KARDEX) //
//////////////////////////

model Movimiento {
  id            String   @id @default(uuid())
  operationId   String   @unique

  productoId    Int
  tipo          TipoMovimiento

  cantidad      Decimal @db.Decimal(12,2)
  precioUnit    Decimal @db.Decimal(12,2)

  entradaBs     Decimal @db.Decimal(12,2) @default(0)
  salidaBs      Decimal @db.Decimal(12,2) @default(0)
  saldoBs       Decimal @db.Decimal(12,2)

  stockAntes    Decimal @db.Decimal(12,2)
  stockDespues  Decimal @db.Decimal(12,2)

  usuarioId     Int
  usuarioEntregaId Int?
  usuarioRecibidoId Int?
  cuentaId      Int?

  referencia    String?
  referenciaId  String?

  createdAt     DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
  usuario  User     @relation("UsuarioRegistro", fields: [usuarioId], references: [id])
  usuarioEntrega User? @relation("UsuarioEntrega", fields: [usuarioEntregaId], references: [id])
  usuarioRecibido User? @relation("UsuarioRecibido", fields: [usuarioRecibidoId], references: [id])
  cuenta   CuentaContable? @relation(fields: [cuentaId], references: [id])
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
}

//////////////////////////
// PROVEEDORES          //
//////////////////////////

model Proveedor {
  id          Int    @id @default(autoincrement())
  nombre      String
  razonSocial String?
  nit         String?
  lugar       String?
  contacto    String?

  compras Compra[]
  pedidos Pedido[]
}

//////////////////////////
// PEDIDOS              //
//////////////////////////

model Pedido {
  id        String   @id @default(uuid())
  proveedorId Int
  estado    EstadoPedido
  createdAt DateTime @default(now())

  observacion String?

  proveedor Proveedor @relation(fields: [proveedorId], references: [id])
  items     PedidoItem[]
}

enum EstadoPedido {
  PENDIENTE
  PARCIAL
  COMPLETADO
}

//////////////////////////
// EXPLORACIÓN MINERA   //
//////////////////////////

enum DrillHoleType {
  DDH
  RC
  AC
  OTHER
}

enum AssayMethod {
  AAS
  ICP
  XRF
  OTHER
}

enum QAQCType {
  BLANK
  DUPLICATE
  STANDARD
}

enum ResourceType {
  OPEN_PIT
  UNDERGROUND
}

enum ResourceCategory {
  MEASURED
  INDICATED
  INFERRED
}

model Project {
  id            Int          @id @default(autoincrement())
  name          String
  description   String?
  location      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdById   Int?
  updatedById   Int?

  zones         Zone[]
  drillHoles    DrillHole[]
  resources     Resource[]
}

model Zone {
  id            Int        @id @default(autoincrement())
  name          String
  description   String?
  projectId     Int
  createdAt     DateTime   @default(now())
  updatedAt     DateTime @updatedAt
  createdById   Int?
  updatedById   Int?

  project       Project    @relation(fields: [projectId], references: [id])
  drillHoles    DrillHole[]

  @@index([projectId])
}

model DrillHole {
  id            Int          @id @default(autoincrement())
  name          String
  projectId     Int
  zoneId        Int

  east          Decimal      @db.Decimal(12,4)
  north         Decimal      @db.Decimal(12,4)
  elevation     Decimal?     @db.Decimal(12,4)

  depth         Decimal      @db.Decimal(12,4)
  azimuth       Decimal?     @db.Decimal(9,4)
  dip           Decimal?     @db.Decimal(9,4)

  type          DrillHoleType
  campaign      String?
  year          Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdById   Int?
  updatedById   Int?

  project       Project      @relation(fields: [projectId], references: [id])
  zone          Zone         @relation(fields: [zoneId], references: [id])
  intervals     Interval[]

  @@index([east, north])
  @@index([projectId])
  @@index([zoneId])
}

model Interval {
  id            Int          @id @default(autoincrement())
  drillHoleId   Int
  fromDepth     Decimal      @db.Decimal(12,4)
  toDepth       Decimal      @db.Decimal(12,4)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdById   Int?
  updatedById   Int?

  drillHole     DrillHole    @relation(fields: [drillHoleId], references: [id])
  assays        Assay[]
  lithologies   Lithology[]

  @@index([drillHoleId])
}

model Assay {
  id            Int          @id @default(autoincrement())
  intervalId    Int

  au            Decimal      @db.Decimal(12,4)
  cu            Decimal      @db.Decimal(12,4)
  ag            Decimal      @db.Decimal(12,4)

  assayMethod   AssayMethod
  laboratory    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdById   Int?
  updatedById   Int?

  interval      Interval     @relation(fields: [intervalId], references: [id])
  qaqcRecords   QAQC[]

  @@index([intervalId])
}

model Lithology {
  id            Int       @id @default(autoincrement())
  intervalId    Int
  rockType      String?
  alteration    String?
  mineralization String?
  comments      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   Int?
  updatedById   Int?

  interval      Interval  @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model QAQC {
  id            Int      @id @default(autoincrement())
  assayId       Int
  type          QAQCType
  passed        Boolean
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   Int?
  updatedById   Int?

  assay         Assay    @relation(fields: [assayId], references: [id])

  @@index([assayId])
}

model Resource {
  id            Int              @id @default(autoincrement())
  projectId     Int
  type          ResourceType
  category      ResourceCategory
  cutoff        Decimal          @db.Decimal(12,4)
  tonnes        Decimal          @db.Decimal(18,2)
  au            Decimal          @db.Decimal(12,4)
  cu            Decimal          @db.Decimal(12,4)
  ag            Decimal          @db.Decimal(12,4)
  cuEq          Decimal          @db.Decimal(12,4)
  description   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  createdById   Int?
  updatedById   Int?

  project       Project          @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model PedidoItem {
  id         String @id @default(uuid())
  pedidoId   String
  productoId Int

  cantidadPedida   Decimal @db.Decimal(12,2)
  cantidadRecibida Decimal @db.Decimal(12,2) @default(0)

  pedido   Pedido  @relation(fields: [pedidoId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
}

//////////////////////////
// COMPRAS              //
//////////////////////////

model Compra {
  id           String   @id @default(uuid())
  proveedorId  Int
  usuarioRegistroId Int
  usuarioRecibidoId Int?
  estado       EstadoCompra
  createdAt    DateTime @default(now())
  recibidoAt   DateTime?

  observacion  String?

  proveedor Proveedor @relation(fields: [proveedorId], references: [id])
  usuarioRegistro User @relation("UsuarioRegistro", fields: [usuarioRegistroId], references: [id])
  usuarioRecibe User? @relation("UsuarioRecibe", fields: [usuarioRecibidoId], references: [id])
  items     CompraItem[]
}

enum EstadoCompra {
  PENDIENTE
  PARCIAL
  COMPLETADO
}

model CompraItem {
  id         String @id @default(uuid())
  compraId   String
  productoId Int

  cantidadPedida   Decimal @db.Decimal(12,2)
  cantidadRecibida Decimal @db.Decimal(12,2) @default(0)
  precioUnit       Decimal @db.Decimal(12,2)

  compra   Compra   @relation(fields: [compraId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
}

//////////////////////////
// VALES                //
//////////////////////////

model Vale {
  id                String   @id @default(uuid())
  solicitanteId     Int
  superintendenteId Int?
  almaceneroId      Int?

  estado            EstadoVale

  aprobadoAt        DateTime?
  entregadoAt       DateTime?

  createdAt         DateTime @default(now())

  solicitante     User @relation("Solicitante", fields: [solicitanteId], references: [id])
  superintendente User? @relation("Supervisor", fields: [superintendenteId], references: [id])
  almacenero      User? @relation("Almacenero", fields: [almaceneroId], references: [id])

  items ValeItem[]
}

enum EstadoVale {
  PENDIENTE
  APROBADO
  PARCIAL
  COMPLETADO
  RECHAZADO
}

model ValeItem {
  id            String @id @default(uuid())
  valeId        String
  productoId    Int

  cantidadSolicitada Decimal @db.Decimal(12,2)
  cantidadEntregada  Decimal @db.Decimal(12,2) @default(0)

  vale     Vale     @relation(fields: [valeId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])
}

//////////////////////////
// EPP                  //
//////////////////////////

model EppAsignacion {
  id         String   @id @default(uuid())
  productoId Int
  usuarioId  Int

  fechaEntrega    DateTime @default(now())
  fechaDevolucion DateTime?

  producto Producto @relation(fields: [productoId], references: [id])
  usuario  User     @relation(fields: [usuarioId], references: [id])
}

//////////////////////////
// LOGS                 //
//////////////////////////

model Log {
  id         String   @id @default(uuid())
  usuarioId  Int
  accion     String
  data       Json
  createdAt  DateTime @default(now())

  usuario User @relation(fields: [usuarioId], references: [id])
}

//////////////////////////
// EXPLORACIONES (MINAS)
//////////////////////////

model Ubicacion {
  id              String @id @default(uuid())

  nivel           String
  este            Float?
  norte           Float?
  elevacion       Float?
  referenciaLugar String?

  createdAt DateTime @default(now())

  muestras  Muestra[]
}

model Muestra {
  id            String   @id @default(uuid())

  nombre        String
  numero        Int?

  laboratorio1  String?
  laboratorio2  String?
  laboratorio3  String?

  tipoMuestra   String?
  sector        String?

  fechaMuestreo DateTime?
  fechaEntrega  DateTime?

  descripcion   String?

  usuarioId     Int?
  usuario       User? @relation(fields: [usuarioId], references: [id])

  ubicacionId   String
  ubicacion     Ubicacion @relation(fields: [ubicacionId], references: [id])

  resultados    Resultado[]

  createdAt     DateTime @default(now())
}

model Elemento {
  id       String @id @default(uuid())
  nombre   String @unique
  unidad   String?

  resultados Resultado[]
}

model Resultado {
  id          String @id @default(uuid())

  muestraId   String
  elementoId  String

  valor       Float?
  prefijo     String? // "<", ">", "~", "=", etc.

  muestra     Muestra  @relation(fields: [muestraId], references: [id])
  elemento    Elemento @relation(fields: [elementoId], references: [id])

  createdAt   DateTime @default(now())

  @@unique([muestraId, elementoId])
}

//////////////////////////
// CONTROL DE PERSONAL  //
//////////////////////////

model Employee {
  id             Int      @id @default(autoincrement())
  nombre         String
  documento      String?  @unique
  deviceUserId   String   @unique
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  syncStatus     SyncStatus @default(PENDING)

  logs AsistenciaLog[]
}

enum SyncStatus {
  PENDING
  SYNCED
  ERROR
}

model SyncQueue {
  id         Int      @id @default(autoincrement())
  action     SyncAction
  payload    Json
  status     SyncStatus @default(PENDING)
  deviceIp   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum SyncAction {
  CREATE
  UPDATE
  DELETE
}

model AsistenciaLog {
  id          Int      @id @default(autoincrement())
  employeeId  Int?
  deviceUserId String
  fecha       DateTime
  tipo        String

  employee Employee? @relation(fields: [employeeId], references: [id])
}


