generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////
// SISTEMA
////////////////////////////////

model Configuracion {
  id           Int          @id @default(autoincrement())
  metodoCosteo MetodoCosteo @default(ULTIMO_PRECIO)
  createdAt    DateTime     @default(now())
}

model User {
  id                    Int             @id @default(autoincrement())
  nombre                String
  email                 String          @unique
  password              String
  role                  Role
  createdAt             DateTime        @default(now())
  resetToken            String?
  resetTokenExpiry      DateTime?
  refreshToken          String?
  refreshTokenExpiry    DateTime?
  activo                Boolean         @default(true)
  comprasRecibidas      Compra[]        @relation("UsuarioRecibe")
  comprasRegistradas    Compra[]        @relation("UsuarioRegistro")
  eppAsignaciones       EppAsignacion[]
  logs                  Log[]
  movimientosEntregados Movimiento[]    @relation("UsuarioEntrega")
  movimientos           Movimiento[]    @relation("UsuarioRegistro")
  movimientosRecibidos  Movimiento[]    @relation("UsuarioRecibido")
  valesEntregadosPor    Vale[]          @relation("Almacenero")
  valesSolicitados      Vale[]          @relation("Solicitante")
  valesAprobados        Vale[]          @relation("Supervisor")
}

model Log {
  id        String   @id @default(uuid())
  usuarioId Int?
  accion    String
  data      Json
  createdAt DateTime @default(now())
  usuario   User?    @relation(fields: [usuarioId], references: [id])
}

////////////////////////////////
// CONTABILIDAD
////////////////////////////////

model CentroCosto {
  id      Int              @id @default(autoincrement())
  codigo  String           @unique
  nombre  String
  cuentas CuentaContable[]
}

model FuncionGasto {
  id      Int              @id @default(autoincrement())
  codigo  String           @unique
  nombre  String
  cuentas CuentaContable[]
}

model Sector {
  id      Int              @id @default(autoincrement())
  codigo  String           @unique
  nombre  String
  cuentas CuentaContable[]
}

model CuentaContable {
  id             Int          @id @default(autoincrement())
  codigoCompleto String       @unique
  centroCostoId  Int
  funcionGastoId Int
  sectorId       Int?
  centroCosto    CentroCosto  @relation(fields: [centroCostoId], references: [id])
  funcionGasto   FuncionGasto @relation(fields: [funcionGastoId], references: [id])
  sector         Sector?      @relation(fields: [sectorId], references: [id])
  movimientos    Movimiento[]
  productos      Producto[]
}

////////////////////////////////
// INVENTARIO
////////////////////////////////

model CategoriaInventario {
  id        Int                   @id @default(autoincrement())
  codigo    String
  nombre    String
  parentId  Int?
  parent    CategoriaInventario?  @relation("Tree", fields: [parentId], references: [id])
  children  CategoriaInventario[] @relation("Tree")
  productos Producto[]
}

model Producto {
  id              Int                 @id @default(autoincrement())
  codigo          String              @unique
  nombre          String
  unidad          String
  categoriaId     Int
  esEpp           Boolean             @default(false)
  cuentaId        Int?
  compraItems     CompraItem[]
  eppAsignaciones EppAsignacion[]
  movimientos     Movimiento[]
  pedidoItems     PedidoItem[]
  categoria       CategoriaInventario @relation(fields: [categoriaId], references: [id])
  cuenta          CuentaContable?     @relation(fields: [cuentaId], references: [id])
  stock           Stock?
  valeItems       ValeItem[]
}

model Stock {
  id         Int      @id @default(autoincrement())
  productoId Int      @unique
  cantidad   Decimal  @db.Decimal(12, 2)
  precioUnit Decimal  @db.Decimal(12, 2)
  precioProm Decimal  @db.Decimal(12, 2)
  updatedAt  DateTime @updatedAt
  producto   Producto @relation(fields: [productoId], references: [id])
}

model Movimiento {
  id                String          @id @default(uuid())
  operationId       String          @unique
  productoId        Int
  tipo              TipoMovimiento
  cantidad          Decimal         @db.Decimal(12, 2)
  precioUnit        Decimal         @db.Decimal(12, 2)
  entradaBs         Decimal         @default(0) @db.Decimal(12, 2)
  salidaBs          Decimal         @default(0) @db.Decimal(12, 2)
  saldoBs           Decimal         @db.Decimal(12, 2)
  stockAntes        Decimal         @db.Decimal(12, 2)
  stockDespues      Decimal         @db.Decimal(12, 2)
  usuarioId         Int
  cuentaId          Int?
  referencia        String?
  referenciaId      String?
  createdAt         DateTime        @default(now())
  usuarioEntregaId  Int?
  usuarioRecibidoId Int?
  cuenta            CuentaContable? @relation(fields: [cuentaId], references: [id])
  producto          Producto        @relation(fields: [productoId], references: [id])
  usuarioEntrega    User?           @relation("UsuarioEntrega", fields: [usuarioEntregaId], references: [id])
  usuario           User            @relation("UsuarioRegistro", fields: [usuarioId], references: [id])
  usuarioRecibido   User?           @relation("UsuarioRecibido", fields: [usuarioRecibidoId], references: [id])
}

////////////////////////////////
// COMPRAS
////////////////////////////////

model Proveedor {
  id          Int      @id @default(autoincrement())
  nombre      String
  contacto    String?
  lugar       String?
  nit         String?
  razonSocial String?
  compras     Compra[]
  pedidos     Pedido[]
}

model Pedido {
  id          String       @id @default(uuid())
  proveedorId Int
  estado      EstadoPedido
  createdAt   DateTime     @default(now())
  observacion String?
  proveedor   Proveedor    @relation(fields: [proveedorId], references: [id])
  items       PedidoItem[]
}

model PedidoItem {
  id               String   @id @default(uuid())
  pedidoId         String
  productoId       Int
  cantidadPedida   Decimal  @db.Decimal(12, 2)
  cantidadRecibida Decimal  @default(0) @db.Decimal(12, 2)
  pedido           Pedido   @relation(fields: [pedidoId], references: [id])
  producto         Producto @relation(fields: [productoId], references: [id])
}

model Compra {
  id                String       @id @default(uuid())
  proveedorId       Int
  estado            EstadoCompra
  createdAt         DateTime     @default(now())
  observacion       String?
  recibidoAt        DateTime?
  usuarioRecibidoId Int?
  usuarioRegistroId Int
  proveedor         Proveedor    @relation(fields: [proveedorId], references: [id])
  usuarioRecibe     User?        @relation("UsuarioRecibe", fields: [usuarioRecibidoId], references: [id])
  usuarioRegistro   User         @relation("UsuarioRegistro", fields: [usuarioRegistroId], references: [id])
  items             CompraItem[]
}

model CompraItem {
  id               String   @id @default(uuid())
  compraId         String
  productoId       Int
  cantidadPedida   Decimal  @db.Decimal(12, 2)
  cantidadRecibida Decimal  @default(0) @db.Decimal(12, 2)
  precioUnit       Decimal  @db.Decimal(12, 2)
  compra           Compra   @relation(fields: [compraId], references: [id])
  producto         Producto @relation(fields: [productoId], references: [id])
}

////////////////////////////////
// VALES / EPP
////////////////////////////////

model Vale {
  id                String     @id @default(uuid())
  solicitanteId     Int
  superintendenteId Int?
  estado            EstadoVale
  aprobadoAt        DateTime?
  entregadoAt       DateTime?
  createdAt         DateTime   @default(now())
  almaceneroId      Int?
  almacenero        User?      @relation("Almacenero", fields: [almaceneroId], references: [id])
  solicitante       User       @relation("Solicitante", fields: [solicitanteId], references: [id])
  superintendente   User?      @relation("Supervisor", fields: [superintendenteId], references: [id])
  items             ValeItem[]
}

model ValeItem {
  id                 String   @id @default(uuid())
  valeId             String
  productoId         Int
  cantidadSolicitada Decimal  @db.Decimal(12, 2)
  cantidadEntregada  Decimal  @default(0) @db.Decimal(12, 2)
  producto           Producto @relation(fields: [productoId], references: [id])
  vale               Vale     @relation(fields: [valeId], references: [id])
}

model EppAsignacion {
  id              String    @id @default(uuid())
  productoId      Int
  usuarioId       Int
  fechaEntrega    DateTime  @default(now())
  fechaDevolucion DateTime?
  producto        Producto  @relation(fields: [productoId], references: [id])
  usuario         User      @relation(fields: [usuarioId], references: [id])
}

////////////////////////////////
// BIOMÉTRICO / ASISTENCIA
////////////////////////////////

model Employee {
  id           Int             @id @default(autoincrement())
  nombre       String
  documento    String?         @unique
  deviceUserId String          @unique
  activo       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  syncStatus   SyncStatus      @default(PENDING)
  logs         AsistenciaLog[]
}

model SyncQueue {
  id        Int        @id @default(autoincrement())
  action    SyncAction
  payload   Json
  status    SyncStatus @default(PENDING)
  deviceIp  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model AsistenciaLog {
  id           Int       @id @default(autoincrement())
  employeeId   Int?
  deviceUserId String
  fecha        DateTime
  tipo         String
  employee     Employee? @relation(fields: [employeeId], references: [id])
}

////////////////////////////////
// EXPLORACIÓN MINERA - SONDAJES / DDH
////////////////////////////////

model Project {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  location    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdById Int?
  updatedById Int?
  drillHoles  DrillHole[]
  resources   Resource[]
  zones       Zone[]
}

model Zone {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  projectId   Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdById Int?
  updatedById Int?
  drillHoles  DrillHole[]
  project     Project     @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model DrillHole {
  id                   Int                    @id @default(autoincrement())
  name                 String
  projectId            Int
  zoneId               Int
  east                 Decimal                @db.Decimal(12, 4)
  north                Decimal                @db.Decimal(12, 4)
  elevation            Decimal?               @db.Decimal(12, 4)
  depth                Decimal                @db.Decimal(12, 4)
  azimuth              Decimal?               @db.Decimal(9, 4)
  dip                  Decimal?               @db.Decimal(9, 4)
  type                 DrillHoleType
  campaign             String?
  year                 Int?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  createdById          Int?
  updatedById          Int?
  project              Project                @relation(fields: [projectId], references: [id])
  zone                 Zone                   @relation(fields: [zoneId], references: [id])
  drillHoleSurveys      DrillHoleSurvey[]
  intervals             Interval[]
  significantIntercepts SignificantIntercept[]

  @@index([east, north])
  @@index([projectId])
  @@index([zoneId])
}

model DrillHoleSurvey {
  id          Int        @id @default(autoincrement())
  drillHoleId Int?
  depth       Decimal    @db.Decimal(12, 4)
  azimuth     Decimal    @db.Decimal(9, 4)
  dip         Decimal    @db.Decimal(9, 4)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  createdById Int?
  updatedById Int?
  drillHole   DrillHole? @relation(fields: [drillHoleId], references: [id])

  @@index([drillHoleId])
}

model Interval {
  id                     Int                      @id @default(autoincrement())
  drillHoleId            Int
  fromDepth              Decimal                  @db.Decimal(12, 4)
  toDepth                Decimal                  @db.Decimal(12, 4)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  createdById            Int?
  updatedById            Int?
  alterations              Alteration[]
  assays                   Assay[]
  densities                Density[]
  geologicalStructures     GeologicalStructure[]
  drillHole                DrillHole                @relation(fields: [drillHoleId], references: [id])
  lithologies              Lithology[]
  magneticSusceptibilities MagneticSusceptibility[]
  mineralizations          Mineralization[]
  recoveries               Recovery[]

  @@index([drillHoleId])
}

model Assay {
  id          Int          @id @default(autoincrement())
  intervalId  Int
  au          Decimal      @db.Decimal(12, 4)
  cu          Decimal      @db.Decimal(12, 4)
  ag          Decimal      @db.Decimal(12, 4)
  assayMethod AssayMethod
  laboratory  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdById Int?
  updatedById Int?
  interval    Interval     @relation(fields: [intervalId], references: [id])
  assayValues AssayValue[]
  qaqcRecords QAQC[]

  @@index([intervalId])
}

model AssayValue {
  id             Int      @id @default(autoincrement())
  assayId        Int?
  element        String
  value          Decimal  @db.Decimal(18, 6)
  unit           String?
  detectionLimit Decimal? @db.Decimal(18, 6)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  createdById    Int?
  updatedById    Int?
  assay          Assay?   @relation(fields: [assayId], references: [id])

  @@index([assayId])
  @@index([element])
}

model QAQC {
  id          Int      @id @default(autoincrement())
  assayId     Int
  type        QAQCType
  passed      Boolean
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById Int?
  updatedById Int?
  assay       Assay    @relation(fields: [assayId], references: [id])

  @@index([assayId])
}

model Lithology {
  id          Int      @id @default(autoincrement())
  intervalId  Int
  rockType    String?
  code        String?
  color       String?
  grainSize   String?
  texture     String?
  weathering  String?
  comments    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById Int?
  updatedById Int?
  interval    Interval @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model Alteration {
  id          Int       @id @default(autoincrement())
  intervalId  Int?
  type        String
  intensity   Decimal?  @db.Decimal(5, 2)
  description String?
  comments    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  createdById Int?
  updatedById Int?
  interval    Interval? @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model Mineralization {
  id          Int       @id @default(autoincrement())
  intervalId  Int?
  mineral     String
  percentage  Decimal?  @db.Decimal(5, 2)
  style       String?
  habit       String?
  description String?
  comments    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  createdById Int?
  updatedById Int?
  interval    Interval? @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model GeologicalStructure {
  id            Int       @id @default(autoincrement())
  intervalId    Int?
  structureType String
  angle         Decimal?  @db.Decimal(9, 4)
  width         Decimal?  @db.Decimal(12, 4)
  orientation   String?
  description   String?
  comments      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  createdById   Int?
  updatedById   Int?
  interval      Interval? @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model Recovery {
  id              Int       @id @default(autoincrement())
  intervalId      Int?
  recoveryPercent Decimal?  @db.Decimal(5, 2)
  rqdPercent      Decimal?  @db.Decimal(5, 2)
  coreLoss        Decimal?  @db.Decimal(12, 4)
  comments        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  createdById     Int?
  updatedById     Int?
  interval        Interval? @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model Density {
  id              Int       @id @default(autoincrement())
  intervalId      Int?
  specificGravity Decimal   @db.Decimal(8, 4)
  method          String?
  dryDensity      Decimal?  @db.Decimal(8, 4)
  wetDensity      Decimal?  @db.Decimal(8, 4)
  comments        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  createdById     Int?
  updatedById     Int?
  interval        Interval? @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model MagneticSusceptibility {
  id          Int       @id @default(autoincrement())
  intervalId  Int?
  value       Decimal   @db.Decimal(18, 6)
  unit        String?
  instrument  String?
  comments    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  createdById Int?
  updatedById Int?
  interval    Interval? @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model Resource {
  id          Int              @id @default(autoincrement())
  projectId   Int
  type        ResourceType
  category    ResourceCategory
  cutoff      Decimal          @db.Decimal(12, 4)
  tonnes      Decimal          @db.Decimal(18, 2)
  au          Decimal          @db.Decimal(12, 4)
  cu          Decimal          @db.Decimal(12, 4)
  ag          Decimal          @db.Decimal(12, 4)
  cuEq        Decimal          @db.Decimal(12, 4)
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdById Int?
  updatedById Int?
  project     Project          @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model SignificantIntercept {
  id          Int       @id @default(autoincrement())
  drillHoleId Int
  isIncluding Boolean   @default(false)
  fromDepth   Decimal   @db.Decimal(12, 4)
  toDepth     Decimal   @db.Decimal(12, 4)
  width       Decimal   @db.Decimal(12, 4)
  trueWidth   Decimal?  @db.Decimal(12, 4)
  au          Decimal?  @db.Decimal(12, 4)
  cu          Decimal?  @db.Decimal(12, 4)
  ag          Decimal?  @db.Decimal(12, 4)
  comments    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  createdById Int?
  updatedById Int?
  drillHole   DrillHole @relation(fields: [drillHoleId], references: [id])

  @@index([drillHoleId])
}

////////////////////////////////
// EXPLORACIÓN SUPERFICIAL / CANALES
////////////////////////////////

model MiningArea {
  id           String        @id @default(uuid())
  name         String
  abbreviation String?
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdById  Int?
  updatedById  Int?
  levels       MiningLevel[]
}

model MiningLevel {
  id           String        @id @default(uuid())
  miningAreaId String
  name         String
  abbreviation String?
  elevation    Float?
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdById  Int?
  updatedById  Int?
  miningArea   MiningArea    @relation(fields: [miningAreaId], references: [id])
  labors       MiningLabor[]

  @@index([miningAreaId])
}

model MiningLabor {
  id            String      @id @default(uuid())
  miningLevelId String
  name          String
  abbreviation  String?
  code          String?
  description   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  createdById   Int?
  updatedById   Int?
  miningLevel   MiningLevel @relation(fields: [miningLevelId], references: [id])
  samples       Sample[]

  @@index([miningLevelId])
}

model Sample {
  id             String             @id @default(uuid())
  miningLaborId  String
  number         Int?
  sampledAt      DateTime?
  name           String?
  sampleType     SampleType?
  code           String             @unique
  placeReference String?
  east           Float?
  north          Float?
  elevation      Float?
  description    String?
  observations   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdById    Int?
  updatedById    Int?
  miningLabor    MiningLabor        @relation(fields: [miningLaborId], references: [id])
  sampleLabs     SampleLaboratory[]
  results        SampleResult[]
  qaqcRecords    SampleQAQC[]

  @@index([miningLaborId])
  @@index([code])
  @@index([east, north])
}

model Laboratory {
  id           String             @id @default(uuid())
  name         String             @unique
  abbreviation String?
  description  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  createdById  Int?
  updatedById  Int?
  sampleLabs   SampleLaboratory[]
}

model SampleLaboratory {
  id           String         @id @default(uuid())
  sampleId     String
  laboratoryId String
  slot         LaboratorySlot
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  createdById  Int?
  updatedById  Int?
  sample       Sample         @relation(fields: [sampleId], references: [id])
  laboratory   Laboratory     @relation(fields: [laboratoryId], references: [id])
  results      SampleResult[]

  @@unique([sampleId, slot])
  @@index([sampleId])
  @@index([laboratoryId])
}

model Element {
  id          String         @id @default(uuid())
  name        String
  symbol      String
  defaultUnit String?
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdById Int?
  updatedById Int?
  results     SampleResult[]

  @@unique([symbol, defaultUnit])
  @@index([symbol])
}

model SampleResult {
  id                 String            @id @default(uuid())
  sampleId           String
  sampleLaboratoryId String?
  elementId          String
  value              Float?
  qualifier          String?
  unit               String?
  sourceColumn       String?
  comments           String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  createdById        Int?
  updatedById        Int?
  sample             Sample            @relation(fields: [sampleId], references: [id])
  sampleLaboratory   SampleLaboratory? @relation(fields: [sampleLaboratoryId], references: [id])
  element            Element           @relation(fields: [elementId], references: [id])

  @@unique([sampleId, sampleLaboratoryId, elementId, unit, sourceColumn])
  @@index([sampleId])
  @@index([sampleLaboratoryId])
  @@index([elementId])
}

model SampleQAQC {
  id               String   @id @default(uuid())
  sampleId         String
  type             String
  passed           Boolean?
  expectedValue    Float?
  obtainedValue    Float?
  deviationPercent Float?
  comments         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdById      Int?
  updatedById      Int?
  sample           Sample   @relation(fields: [sampleId], references: [id])

  @@index([sampleId])
}

////////////////////////////////
// ENUMS
////////////////////////////////

enum MetodoCosteo {
  ULTIMO_PRECIO
  PROMEDIO_PONDERADO
}

enum Role {
  ADMIN
  ALMACENERO
  SUPERINTENDENTE
  TRABAJADOR
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
}

enum EstadoPedido {
  PENDIENTE
  PARCIAL
  COMPLETADO
}

enum EstadoCompra {
  PENDIENTE
  PARCIAL
  COMPLETADO
}

enum EstadoVale {
  PENDIENTE
  APROBADO
  PARCIAL
  COMPLETADO
  RECHAZADO
}

enum SyncStatus {
  PENDING
  SYNCED
  ERROR
}

enum SyncAction {
  CREATE
  UPDATE
  DELETE
}

enum DrillHoleType {
  DDH
  RC
  AC
  OTHER
}

enum AssayMethod {
  AAS
  ICP
  XRF
  OTHER
}

enum QAQCType {
  BLANK
  DUPLICATE
  STANDARD
}

enum ResourceType {
  OPEN_PIT
  UNDERGROUND
}

enum ResourceCategory {
  MEASURED
  INDICATED
  INFERRED
}

enum SampleType {
  SIMPLE
  DOUBLE
  SIMPLE_DOUBLE
  OTHER
}

enum LaboratorySlot {
  L1
  L2
  L3
}
